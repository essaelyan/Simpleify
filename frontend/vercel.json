{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npx prisma generate && npx prisma db push && next build",
  "installCommand": "npm install",
  "functions": {
    "src/pages/api/pipeline/run.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/social/scheduled/process",
      "schedule": "0 * * * *"
    }
  ]
}
