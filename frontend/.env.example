# ─── AI Marketing OS — Environment Variables ──────────────────────────────────
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local — it is already in .gitignore.

# ── Required ──────────────────────────────────────────────────────────────────

# Anthropic / Claude
# Get yours at https://console.anthropic.com/
CLAUDE_API_KEY=sk-ant-...

# PostgreSQL connection string (Neon, Supabase, Railway, etc.)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# ── Social Publishing ─────────────────────────────────────────────────────────

# Set to "false" to enable real social platform publishing.
# Default: "true" (mock mode — safe for development and staging).
SOCIAL_PUBLISH_MOCK=true

# ── Twitter / X ───────────────────────────────────────────────────────────────
# OAuth 2.0 Bearer Token with tweet.write scope.
# Generate at https://developer.twitter.com/en/portal/projects
# TWITTER_ACCESS_TOKEN=

# ── Facebook ──────────────────────────────────────────────────────────────────
# Page Access Token with pages_manage_posts permission.
# Generate via Facebook Graph API Explorer or your app's OAuth flow.
# FACEBOOK_ACCESS_TOKEN=

# ── Instagram ─────────────────────────────────────────────────────────────────
# Long-lived User Access Token with instagram_content_publish permission.
# Get via Facebook App → Instagram Basic Display → access token tool.
# INSTAGRAM_ACCESS_TOKEN=
# Your Instagram Business Account numeric ID (not username).
# INSTAGRAM_BUSINESS_ACCOUNT_ID=

# ── LinkedIn ──────────────────────────────────────────────────────────────────
# OAuth 2.0 Bearer Token with w_member_social scope.
# Author URN format: urn:li:person:XXXXXXXX  (or urn:li:organization:XXXXXXXX for pages)
# LINKEDIN_ACCESS_TOKEN=
# LINKEDIN_AUTHOR_URN=urn:li:person:XXXXXXXX

# ── TikTok ────────────────────────────────────────────────────────────────────
# OAuth 2.0 Access Token from TikTok for Business API.
# Requires Content Posting API access (applied separately).
# TIKTOK_ACCESS_TOKEN=

# ── Google Analytics 4 (optional — feedback loop) ────────────────────────────
# When these are set, the feedback loop pulls real GA4 data.
# When missing, realistic mock data is used automatically.
#
# 1. Create a service account at https://console.cloud.google.com/iam-admin/serviceaccounts
# 2. Grant it "Viewer" role on your GA4 property
# 3. Download the JSON key and extract client_email + private_key
# GA4_PROPERTY_ID=123456789
# GA4_CLIENT_EMAIL=my-sa@my-project.iam.gserviceaccount.com
# GA4_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# ── Vercel deployment (set automatically by Vercel, do not set manually) ──────
# VERCEL_URL is injected by Vercel for internal API-to-API calls in pipeline/run.ts
# VERCEL_URL=simpleify.vercel.app
