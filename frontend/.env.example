# ─── AI Marketing OS — Environment Variables ──────────────────────────────────
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local — it is already in .gitignore.
#
# On Vercel, set these in: Project Settings → Environment Variables
# All variables marked [required] must be present or the app will not start.

# ── Database [required] ───────────────────────────────────────────────────────
# PostgreSQL connection string.
# Providers: Neon (recommended), Supabase, Railway, PlanetScale Postgres, etc.
# Format:    postgresql://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=require
DATABASE_URL=

# ── AI / Claude [required] ────────────────────────────────────────────────────
# Anthropic API key. All AI agents (content, QA, safety, enrichment, feedback)
# use this key. The pipeline returns a clear 500 if this is missing.
# Get yours at: https://console.anthropic.com/
CLAUDE_API_KEY=

# ── Social publishing mode [required] ─────────────────────────────────────────
# Controls whether the social publisher calls real platform APIs or returns
# a mock post ID.
#   true  — mock mode (safe for local dev and preview environments)
#   false — live mode (only set on production with tokens configured below)
SOCIAL_PUBLISH_MOCK=true

# ── Twitter / X [optional — real publishing only] ─────────────────────────────
# OAuth 2.0 Bearer Token with tweet.write scope.
# Only read when SOCIAL_PUBLISH_MOCK=false.
# Generate at: https://developer.twitter.com/en/portal/projects
# TWITTER_ACCESS_TOKEN=

# ── Facebook [optional — real publishing only] ────────────────────────────────
# Page Access Token with pages_manage_posts permission.
# Generate via Facebook Graph API Explorer or your app's OAuth flow.
# Only read when SOCIAL_PUBLISH_MOCK=false.
# FACEBOOK_ACCESS_TOKEN=

# ── Instagram [optional — real publishing only] ───────────────────────────────
# Long-lived User Access Token with instagram_content_publish permission.
# Get via: Facebook App → Instagram Basic Display → access token tool.
# Only read when SOCIAL_PUBLISH_MOCK=false.
# INSTAGRAM_ACCESS_TOKEN=
# Numeric Instagram Business Account ID (not the @username).
# INSTAGRAM_BUSINESS_ACCOUNT_ID=

# ── LinkedIn [optional — real publishing only] ────────────────────────────────
# OAuth 2.0 Bearer Token with w_member_social scope.
# Only read when SOCIAL_PUBLISH_MOCK=false.
# Author URN format:
#   person page: urn:li:person:XXXXXXXX
#   company page: urn:li:organization:XXXXXXXX
# The pipeline fails fast with a clear error if LINKEDIN_AUTHOR_URN is missing
# while publishing to LinkedIn.
# LINKEDIN_ACCESS_TOKEN=
# LINKEDIN_AUTHOR_URN=

# ── TikTok [optional — real publishing only] ──────────────────────────────────
# OAuth 2.0 Access Token from TikTok for Business API.
# Requires Content Posting API access (applied for separately in TikTok portal).
# Only read when SOCIAL_PUBLISH_MOCK=false.
# TIKTOK_ACCESS_TOKEN=

# ── Google Analytics 4 [optional — feedback loop] ────────────────────────────
# When these three vars are set, the feedback loop fetches real GA4 engagement
# data and uses it to tune content generation hints.
# When any are missing, the feedback loop falls back to realistic mock data
# automatically — the pipeline does not fail.
#
# Setup:
#   1. Create a service account: https://console.cloud.google.com/iam-admin/serviceaccounts
#   2. Grant it "Viewer" role on your GA4 property.
#   3. Download the JSON key file and copy client_email + private_key from it.
# GA4_PROPERTY_ID=
# GA4_CLIENT_EMAIL=
# GA4_PRIVATE_KEY=
